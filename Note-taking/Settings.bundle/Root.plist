<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>StringsTable</key>
    <string>Root</string>
    <key>PreferenceSpecifiers</key>
    <array>
        <dict>
            <key>Type</key>
            <string>PSGroupSpecifier</string>
            <key>Title</key>
            <string>Calendar Sync</string>
            <key>FooterText</key>
            <string>Local Google: requires your Google account in iOS Settings → Mail → Accounts. Web Google: signs you in via browser — no account setup needed.</string>
        </dict>
        <dict>
            <key>Type</key>
            <string>PSToggleSwitchSpecifier</string>
            <key>Title</key>
            <string>Apple Calendar</string>
            <key>Key</key>
            <string>appleCalendarSyncEnabled</string>
            <key>DefaultValue</key>
            <true/>
        </dict>
        <dict>
            <key>Type</key>
            <string>PSToggleSwitchSpecifier</string>
            <key>Title</key>
            <string>Local Google Calendar</string>
            <key>Key</key>
            <string>googleCalendarSyncEnabled</string>
            <key>DefaultValue</key>
            <false/>
        </dict>
        <dict>
            <key>Type</key>
            <string>PSToggleSwitchSpecifier</string>
            <key>Title</key>
            <string>Web Google Calendar</string>
            <key>Key</key>
            <string>googleWebCalendarEnabled</string>
            <key>DefaultValue</key>
            <false/>
        </dict>
    </array>
</dict>
</plist>
